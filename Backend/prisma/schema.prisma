generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
model User {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invites   Invite[] @relation("UserInvites")
  rooms     Room[]   @relation("UserRooms")
}

model FirstYearSubject {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String    @unique
  slug               String    @unique
  description        String    @default("Explore resources for this subject.")
  notes              Json
  pyqs               Json
  cho                Json
  assignments        Json
  importantQuestions Json
  videoResources     Json
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model SecondYearSubject {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String    @unique
  slug               String    @unique
  description        String    @default("Explore resources for this subject.")
  notes              Json
  pyqs               Json
  cho                Json
  assignments        Json
  importantQuestions Json
  videoResources     Json
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Invite {
  id         String   @id @default(uuid()) @db.Uuid
  email      String
  token      String   @unique
  status     String   @default("pending")
  senderId   String?  @db.Uuid
  topic      String?
  difficulty String?
  sender     User?    @relation(fields: [senderId], references: [id], name: "UserInvites")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Room {
  id          String   @id @default(uuid()) @db.Uuid
  roomId      String   @unique
  topic       String?
  difficulty  String?
  createdById String?  @db.Uuid
  createdBy   User?    @relation(fields: [createdById], references: [id], name: "UserRooms")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
