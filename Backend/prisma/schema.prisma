generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

type Resource {
  title String
  link  String
  type  String
}

model User {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invites   Invite[] @relation("UserInvites")
  rooms     Room[]   @relation("UserRooms")
}

model FirstYearSubject {
  id                 String    @id @map("_id") @default(auto()) @db.ObjectId
  name               String    @unique
  slug               String    @unique
  description        String    @default("Explore resources for this subject.")
  notes              Resource[]
  pyqs               Resource[]
  cho                Resource[]
  assignments        Resource[]
  importantQuestions Resource[]
  videoResources     Resource[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model SecondYearSubject {
  id                 String    @id @map("_id") @default(auto()) @db.ObjectId
  name               String    @unique
  slug               String    @unique
  description        String    @default("Explore resources for this subject.")
  notes              Resource[]
  pyqs               Resource[]
  cho                Resource[]
  assignments        Resource[]
  importantQuestions Resource[]
  videoResources     Resource[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Invite {
  id         String   @id @map("_id") @default(auto()) @db.ObjectId
  email      String
  token      String   @unique
  status     String   @default("pending")
  senderId   String?  @db.ObjectId
  topic      String?
  difficulty String?
  sender     User?    @relation(fields: [senderId], references: [id], name: "UserInvites")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Room {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  roomId      String   @unique
  topic       String?
  difficulty  String?
  createdById String?  @db.ObjectId
  createdBy   User?    @relation(fields: [createdById], references: [id], name: "UserRooms")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
